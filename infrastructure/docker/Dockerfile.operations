# Deep Agent (电商运营) 专用 Dockerfile
FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml .
RUN pip install --no-cache-dir \
    fastapi uvicorn[standard] langgraph langchain langchain-openai \
    langchain-anthropic deepagents redis sqlalchemy asyncpg pgvector \
    psycopg2-binary alembic pydantic pydantic-settings structlog httpx \
    openai anthropic litellm chromadb apscheduler python-jose passlib \
    prometheus-client opentelemetry-api opentelemetry-sdk \
    opentelemetry-instrumentation-fastapi opentelemetry-exporter-otlp \
    tenacity python-multipart

COPY shared/ ./shared/
RUN pip install -e ./shared/

COPY services/ ./services/

HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD curl -f http://localhost:8005/health || exit 1

CMD ["uvicorn", "services.operations.main:app", "--host", "0.0.0.0", "--port", "8005"]
