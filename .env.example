# ============================================
# Agent Cluster 环境变量模板
# ============================================

# --- 环境 ---
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# --- 数据库 ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agent_cluster
POSTGRES_USER=agent
POSTGRES_PASSWORD=change-me-in-production

# PostgreSQL 连接串（异步）
DATABASE_URL=postgresql+asyncpg://agent:change-me-in-production@localhost:5432/agent_cluster
DATABASE_URL_SYNC=postgresql+psycopg2://agent:change-me-in-production@localhost:5432/agent_cluster

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- LLM 配置 ---
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# 默认模型
DEFAULT_MODEL=claude-sonnet-4-6
FAST_MODEL=claude-haiku-4-5
VISION_MODEL=claude-sonnet-4-6

# --- Embedding ---
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# --- 网关 ---
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_WORKERS=4

# --- JWT ---
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- 服务发现 ---
SUPERVISOR_URL=http://supervisor:8001
TELEMARKETING_URL=http://telemarketing:8002
LIVE_URL=http://live:8003
CUSTOMER_SERVICE_URL=http://customer-service:8004
OPERATIONS_URL=http://operations:8005
CONTENT_URL=http://content:8006
OFFICE_URL=http://office:8007

# --- 可观测性 ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
PROMETHEUS_PORT=9090

# --- 限流 ---
RATE_LIMIT_PER_SECOND=100
RATE_LIMIT_BURST=200

# --- 飞书/钉钉 ---
FEISHU_WEBHOOK_URL=
DINGTALK_WEBHOOK_URL=
